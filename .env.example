# Copy to .env and fill in. Without this file, the bot uses in-memory data
# and deterministic routing — no API keys required.

# "postgres" for Supabase/Postgres storage, unset (or "memory") for in-memory
SUPPORTBOT_DATA_BACKEND=postgres

# Supabase/Postgres connection string
DATABASE_URL=

# Voyage AI embeddings + rerank
VOYAGE_API_KEY=

# Claude API (Haiku + Sonnet)
ANTHROPIC_API_KEY=

# Optional: path to the Olist dataset, only needed when importing sample data
# OLIST_DATASET_DIR=
